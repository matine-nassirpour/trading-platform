{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/HealthResponse",
  "$defs": {
    "HealthResponse": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "OK",
            "DEGRADED",
            "FAILING"
          ]
        }
      },
      "required": [
        "status"
      ],
      "additionalProperties": false
    }
  }
}
