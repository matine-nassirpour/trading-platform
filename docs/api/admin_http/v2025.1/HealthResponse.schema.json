{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/HealthResponse",
  "$defs": {
    "JsonValue": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/JsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          }
        }
      ]
    },
    "HealthResponse": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "OK",
            "DEGRADED",
            "FAILING"
          ]
        }
      },
      "required": [
        "status"
      ],
      "additionalProperties": false
    }
  }
}
