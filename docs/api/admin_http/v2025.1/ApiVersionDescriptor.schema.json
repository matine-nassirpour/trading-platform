{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/ApiVersionDescriptor",
  "$defs": {
    "JsonValue": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/JsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          }
        }
      ]
    },
    "ApiVersionDescriptor": {
      "type": "object",
      "properties": {
        "year": {
          "type": "integer"
        },
        "revision": {
          "type": "integer"
        }
      },
      "required": [
        "year",
        "revision"
      ],
      "additionalProperties": false
    }
  }
}
