# ╭────────────────────────────────────────────────────────────────────────────╮
# │ Identity                                                                   │
# ╰────────────────────────────────────────────────────────────────────────────╯
QUANTUM_APP_NAME=python_core
QUANTUM_APP_VERSION=0.1.0+dev
QUANTUM_ENV=dev
QUANTUM_NS=quantum
QUANTUM_INSTANCE_ID=
QUANTUM_ADMIN_HTTP_HOST=127.0.0.1
QUANTUM_ADMIN_HTTP_PORT=8765
QUANTUM_ADMIN_HTTP_ENABLED=true
QUANTUM_ADMIN_HTTP_BASE_PATH="/"

# ╭────────────────────────────────────────────────────────────────────────────╮
# │ Logging                                                                    │
# ╰────────────────────────────────────────────────────────────────────────────╯
QUANTUM_LOG_LEVEL=INFO
QUANTUM_LOG_SAMPLE_INFO=10            # 0 = no sampling; 10 = ~1/10 of the INFO logs (if your sampler supports it)
QUANTUM_LOG_RATELIMIT=false           # true to enable the rate limiter
QUANTUM_LOG_RPS=100                   # tokens/s if QUANTUM_LOG_RATELIMIT=1
QUANTUM_LOG_FSYNC=false               # true = fsync on every write (POSIX only)
QUANTUM_LOG_MAX_BYTES=10485760        # 10 MiB per log file
QUANTUM_LOG_WARN_BYTES=0              # 0 = no “nearing size threshold” alert in dev

# ─── Local storage (opt-in)
QUANTUM_LOG_DIR=D:/projects/trading-platform/_logs
QUANTUM_AUDIT_DIR=D:/projects/trading-platform/_audit
QUANTUM_AUDIT_ALLOWLIST=order_intent, order_fill, order_submit,   # Possible CSV: order_submit_v1, order_fill_v1, etc.

# ╭────────────────────────────────────────────────────────────────────────────╮
# │ Tracing                                                                    │
# ╰────────────────────────────────────────────────────────────────────────────╯
QUANTUM_TRACE_EXPORTER=console        # otlp | console | none
QUANTUM_TRACE_OTLP_ENDPOINT=http://127.0.0.1:4318
QUANTUM_TRACE_OTLP_PROTOCOL=http      # http | grpc
QUANTUM_TRACE_OTLP_HEADERS=           # ex: Authorization=Bearer <token>,x-otlp-api-key=xxx
QUANTUM_TRACE_OTLP_TIMEOUT_MS=1000
QUANTUM_TRACE_OTLP_COMPRESSION=none   # gzip | none
QUANTUM_TRACE_OTLP_INSECURE=true      # useful especially for local gRPC
QUANTUM_TRACE_SAMPLE=1.0

# ╭────────────────────────────────────────────────────────────────────────────╮
# │ Metrics                                                                    │
# ╰────────────────────────────────────────────────────────────────────────────╯
QUANTUM_METRICS_HOST=0.0.0.0
QUANTUM_METRICS_PORT=9464             # 0 to disable; 9464 to expose /metrics

# ╭────────────────────────────────────────────────────────────────────────────╮
# │ MetaTrader5 Credentials (multi-channel)                                    │
# │ Each prop firm or broker has its own credentials.                          │
# │ Required variables for each channel (case-insensitive):                    │
# │   QUANTUM_MT5_<CHANNEL>_LOGIN                                              │
# │   QUANTUM_MT5_<CHANNEL>_SERVER                                             │
# │   QUANTUM_MT5_<CHANNEL>_PASSWORD                                           │
# │ Channels supported: FTMO, FUNDEDNEXT                                       │
# ╰────────────────────────────────────────────────────────────────────────────╯

# ─── FTMO account
QUANTUM_MT5_FTMO_LOGIN=1234567
QUANTUM_MT5_FTMO_SERVER=FTMO-Demo
QUANTUM_MT5_FTMO_PASSWORD=your_ftmo_password

# ─── FUNDEDNEXT account
QUANTUM_MT5_FUNDEDNEXT_LOGIN=7654321
QUANTUM_MT5_FUNDEDNEXT_SERVER=FundedNext-Live
QUANTUM_MT5_FUNDEDNEXT_PASSWORD=your_fundednext_password

# ╭────────────────────────────────────────────────────────────────────────────╮
# │ MetaTrader5 - Terminal Executables                                         │
# ╰────────────────────────────────────────────────────────────────────────────╯
QUANTUM_MT5_FTMO_TERMINAL_PATH="C:/Program Files/FTMO Global Markets MT5 Terminal/terminal64.exe"
QUANTUM_MT5_FUNDEDNEXT_TERMINAL_PATH="C:/Program Files/FundedNext MT5 Terminal/terminal64.exe"

# ╭────────────────────────────────────────────────────────────────────────────╮
# │ Execution Resilience Policy                                                │
# ╰────────────────────────────────────────────────────────────────────────────╯
QUANTUM_EXEC_TIMEOUT=5.0              # seconds before timeout
QUANTUM_EXEC_RETRIES=3                # max retry attempts
QUANTUM_EXEC_BACKOFF=0.5              # base backoff in seconds
QUANTUM_EXEC_BACKOFF_MAX=5.0          # max backoff cap in seconds
