# Identity
QUANTUM_APP_NAME=python_core
QUANTUM_APP_VERSION=0.1.0+dev
QUANTUM_ENV=dev
QUANTUM_NS=quantum

# Logging / Tracing
QUANTUM_LOG_LEVEL=INFO
QUANTUM_LOG_SAMPLE_INFO=10          # 0 = no sampling; 10 = ~1/10 of the INFO logs (if your sampler supports it)
QUANTUM_LOG_RATELIMIT=1             # keep 1 msg/s if you have a rate limiter (otherwise leave 0)
QUANTUM_LOG_FSYNC=0                 # Windows: leave 0 (faster, no O_DIRECTORY)
QUANTUM_LOG_MAX_BYTES=10485760      # 10 MiB per log file (comfortable dev)
QUANTUM_LOG_WARN_BYTES=0            # 0 = no “nearing size threshold” alert in dev

QUANTUM_TRACE_SAMPLE=1.0
QUANTUM_TRACE_EXPORTER=console      # otlp | console | none
QUANTUM_TRACE_OTLP_PROTOCOL=http    # http | grpc
QUANTUM_TRACE_OTLP_ENDPOINT=http://127.0.0.1:4318
QUANTUM_TRACE_OTLP_HEADERS=         # ex: Authorization=Bearer <token>,x-otlp-api-key=xxx
QUANTUM_TRACE_OTLP_TIMEOUT_MS=1000
QUANTUM_TRACE_OTLP_COMPRESSION=none # gzip | none
QUANTUM_TRACE_OTLP_INSECURE=1       # useful especially for local gRPC

# Local storage (opt-in)
QUANTUM_LOG_DIR=./_logs             # Partitioned JSONL
QUANTUM_AUDIT_DIR=./_audit          # 1 JSON per critical event
QUANTUM_AUDIT_EVENTS=order_submit_v1
QUANTUM_AUDIT_EVENTS_VERSION=v1

# Metrics (opt-in)
QUANTUM_METRICS_PORT=9200           # 0 to disable; 9200 to expose /metrics
QUANTUM_METRICS_ADDR=0.0.0.0


STREAMLIT_LOG_TZ=utc                # utc | local
STREAMLIT_LOG_RENDERER=json         # json | code
STREAMLIT_LOG_EXPANDED=0            # # Expanders: 1 = open; 0 or unset = closed (default, case-insensitive)
