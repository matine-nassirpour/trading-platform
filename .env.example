# Identity
QUANTUM_APP_NAME=python_core
QUANTUM_ENV=dev
QUANTUM_NS=quantum

# Logging / Tracing
QUANTUM_LOG_LEVEL=INFO
QUANTUM_LOG_SAMPLE_INFO=10
QUANTUM_LOG_RATELIMIT=1
QUANTUM_TRACE_SAMPLE=1.0     # ∈ [0..1]
QUANTUM_TRACE_EXPORTER=console

# Local storage (opt-in)
QUANTUM_LOG_DIR=./_logs      # Partitioned JSONL
QUANTUM_AUDIT_DIR=./_audit   # 1 JSON file per critical event

# Metrics (opt-in)
QUANTUM_METRICS_PORT=9200
QUANTUM_METRICS_ADDR=0.0.0.0
