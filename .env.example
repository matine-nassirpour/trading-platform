# Identity
QUANTUM_APP_NAME=python_core
QUANTUM_ENV=dev
QUANTUM_NS=quantum

# Logging / Tracing
QUANTUM_LOG_LEVEL=INFO
QUANTUM_TRACE_SAMPLE=1.0
QUANTUM_TRACE_EXPORTER=console  # console|none

# Local storage (opt-in)
QUANTUM_LOG_DIR=./_logs      # JSONL partitioned by time (if defined)
QUANTUM_AUDIT_DIR=./_audit   # 1 JSON file per critical event (if defined)

# Metrics (opt-in)
QUANTUM_METRICS_PORT=9200
QUANTUM_METRICS_ADDR=0.0.0.0
